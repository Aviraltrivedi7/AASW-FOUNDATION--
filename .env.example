# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Admin Authentication
# Generate a secure random string for production: openssl rand -hex 64
JWT_SECRET=your_secure_jwt_secret_here

# CORS - Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Fast2SMS Configuration (for Mobile OTP)
# Get your API key from: https://fast2sms.com
FAST2SMS_API_KEY=your_fast2sms_api_key

# SMTP Email Configuration (for OTP & Contact Form)
CONTACT_EMAIL=your_email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=your_email@gmail.com

# Razorpay Payment Gateway
# Test Mode Keys (for development)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# MongoDB (PRIMARY Database)
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/aasw-foundation?retryWrites=true&w=majority
# Local: mongodb://localhost:27017/aasw-foundation
MONGODB_URI=mongodb://localhost:27017/aasw-foundation

# InsForge Backend Configuration (SECONDARY / Fallback + Sync)
INSFORGE_URL=https://your-app.region.insforge.app
INSFORGE_KEY=your_insforge_anon_key

# ============================================
# PRODUCTION DEPLOYMENT CHECKLIST:
# ============================================
# 1. Generate new JWT_SECRET using: openssl rand -hex 64
# 2. Replace Razorpay test keys with live keys (rzp_live_*)
# 3. Set NODE_ENV=production
# 4. Add production domain to ALLOWED_ORIGINS
# 5. Configure proper SMTP credentials
# 6. Set secure RAZORPAY_WEBHOOK_SECRET
# ============================================
