{
  "name": "aasw-foundation-website",
  "version": "1.0.0",
  "description": "Official website for AASW Foundation — membership, donations, and social impact.",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch-path=./src --watch-path=./server.js server.js",
    "build:css": "node tools/build-tailwind.js",
    "build:minify": "node tools/minify_script.js",
    "build:images": "node tools/optimize_images.js",
    "build": "npm run build:css && npm run build:minify && npm run build:images",
    "prebuild": "echo Starting production build..."
  },
  "dependencies": {
    "@insforge/sdk": "^1.2.5",
    "@supabase/postgrest-js": "^2.105.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.1",
    "nodemailer": "^6.10.0",
    "pdf-lib": "^1.17.1",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "3.4",
    "terser": "^5.46.0"
  }
}
