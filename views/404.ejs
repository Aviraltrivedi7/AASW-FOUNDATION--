<!DOCTYPE html>
<html class="dark" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>AASW Foundation | Page Not Found</title>
<link rel="icon" type="image/png" href="/images/logo.png">
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Space+Grotesk:wght@300;500;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script>
tailwind.config = {
  darkMode: "class",
  theme: { extend: {
    colors: {
      "primary": "#94aaff", "primary-container": "#869cf0", "secondary": "#cb7bff",
      "background": "#0e0e0f", "surface": "#0e0e0f",
      "surface-container": "#19191b", "on-surface": "#ffffff", "on-surface-variant": "#adaaab",
      "on-primary": "#072776",
    },
    fontFamily: { "headline": ["Manrope"], "body": ["Manrope"], "label": ["Space Grotesk"] }
  }}
}
</script>
<style>
  body { background-color: #0e0e0f; color: #ffffff; }
  .text-gradient { background: linear-gradient(45deg, #94aaff, #cb7bff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .btn-glow:hover { box-shadow: 0 0 30px rgba(148, 170, 255, 0.4); }
  .aura-blue { background: radial-gradient(circle at center, rgba(148, 170, 255, 0.12) 0%, transparent 70%); }
  .aura-purple { background: radial-gradient(circle at center, rgba(203, 123, 255, 0.12) 0%, transparent 70%); }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }
  .float { animation: float 4s ease-in-out infinite; }
</style>
</head>
<body class="font-body min-h-screen flex items-center justify-center overflow-hidden relative">

<div class="fixed -top-20 -right-20 w-[600px] h-[600px] aura-blue blur-[120px] opacity-30"></div>
<div class="fixed -bottom-20 -left-20 w-[600px] h-[600px] aura-purple blur-[120px] opacity-20"></div>

<div class="relative z-10 text-center px-6 max-w-lg">
  <div class="float mb-8">
    <span class="material-symbols-outlined text-primary" style="font-size: 120px; font-variation-settings: 'FILL' 0, 'wght' 200;">explore_off</span>
  </div>
  <h1 class="text-7xl md:text-9xl font-headline font-extrabold text-gradient mb-4">404</h1>
  <h2 class="text-2xl md:text-3xl font-headline font-bold text-white mb-4">Page Not Found</h2>
  <p class="text-on-surface-variant text-lg leading-relaxed mb-10">The page you're looking for doesn't exist or has been moved.</p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center">
    <a href="/" class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-10 py-4 rounded-xl font-label text-sm font-bold uppercase tracking-widest btn-glow transition-all text-center">
      Back to Home
    </a>
    <a href="/membership.html" class="bg-surface-container border border-white/10 text-white px-10 py-4 rounded-xl font-label text-sm font-bold uppercase tracking-widest hover:bg-white/5 transition-all text-center">
      Membership
    </a>
  </div>
  <p class="mt-12 font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant/40">© 2025 AASW Foundation</p>
</div>


<!-- Toast Container -->
<div id="toast" class="toast"></div>

<style>
  /* Toast notification */
  .toast { position: fixed; bottom: 2rem; right: 2rem; padding: 1rem 1.5rem; border-radius: 0.75rem; z-index: 100; transform: translateY(100px); opacity: 0; transition: all 0.4s ease; pointer-events: none; }
  .toast.show { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .toast.success { background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3); color: #22c55e; backdrop-filter: blur(20px); }
  .toast.error { background: rgba(255, 110, 132, 0.15); border: 1px solid rgba(255, 110, 132, 0.3); color: #ff6e84; backdrop-filter: blur(20px); }
</style>

<script>
// ====== TOAST NOTIFICATION ======
function showToast(message, type = 'success') {
  let toast = document.getElementById('toast');
  if(!toast) return;
  toast.textContent = message;
  toast.className = 'toast ' + type + ' show';
  setTimeout(() => toast.classList.remove('show'), 4000);
}

// ====== GENERIC FORM HANDLERS ======
document.querySelectorAll('form').forEach(form => {
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameInput = form.querySelector('input[placeholder*="Doe"]');
    const emailInput = form.querySelector('input[type="email"]');
    const msgInput = form.querySelector('textarea');
    const btn = form.querySelector('button');
    const originalText = btn ? btn.textContent : 'Sending...';
    
    // Contact form check
    if (nameInput && emailInput && msgInput) {
        if (btn) { btn.textContent = 'Sending...'; btn.disabled = true; }
        try {
          const res = await fetch('/api/v1/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: nameInput.value,
              email: emailInput.value,
              subject: 'Contact from Stitch UI',
              message: msgInput.value
            })
          });
          if (res.ok) {
            showToast('✓ Message sent successfully!', 'success');
            form.reset();
          } else {
            showToast('Failed to send message', 'error');
          }
        } catch (err) {
          showToast('Network error. Please try again.', 'error');
        } finally {
          if (btn) { btn.textContent = originalText; btn.disabled = false; }
        }
    }
  });
});
</script>

</body>
</html>
