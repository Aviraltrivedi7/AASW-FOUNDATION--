<!DOCTYPE html>
<html class="dark" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>AASW Admin | Dashboard</title>
<link rel="icon" type="image/png" href="/images/logo.png">
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Space+Grotesk:wght@300;500;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script>
tailwind.config = {
  darkMode: "class",
  theme: { extend: {
    colors: {
      "primary": "#94aaff", "primary-container": "#869cf0", "secondary": "#cb7bff", "secondary-container": "#6c169f",
      "tertiary": "#94bdff", "tertiary-container": "#7daffc",
      "background": "#0e0e0f", "surface": "#0e0e0f",
      "surface-container-lowest": "#000000", "surface-container-low": "#131314",
      "surface-container": "#19191b", "surface-container-high": "#201f21", "surface-container-highest": "#262627",
      "surface-variant": "#262627", "on-surface": "#ffffff", "on-surface-variant": "#adaaab",
      "on-primary": "#072776", "on-primary-container": "#001b60",
      "outline": "#767576", "outline-variant": "#484849", "error": "#ff6e84",
    },
    fontFamily: { "headline": ["Manrope","sans-serif"], "body": ["Manrope","sans-serif"], "label": ["Space Grotesk","sans-serif"] }
  }}
}
</script>
<style>
  body { background-color: #0e0e0f; color: #ffffff; font-family: 'Manrope', sans-serif; overflow-x: hidden; }
  .aura-blue { background: radial-gradient(circle at top left, rgba(148, 170, 255, 0.12) 0%, transparent 50%); }
  .aura-violet { background: radial-gradient(circle at bottom right, rgba(203, 123, 255, 0.1) 0%, transparent 50%); }
  .glass-card { background: rgba(25, 25, 27, 0.4); backdrop-filter: blur(12px); border: 1px solid rgba(148, 170, 255, 0.05); }
  .btn-glow:hover { box-shadow: 0 0 20px rgba(148, 170, 255, 0.4); }
  .toast { position: fixed; bottom: 2rem; right: 2rem; padding: 1rem 1.5rem; border-radius: 0.75rem; z-index: 100; transform: translateY(100px); opacity: 0; transition: all 0.4s ease; }
  .toast.show { transform: translateY(0); opacity: 1; }
  .toast.success { background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3); color: #22c55e; backdrop-filter: blur(20px); }
  .toast.error { background: rgba(255, 110, 132, 0.15); border: 1px solid rgba(255, 110, 132, 0.3); color: #ff6e84; backdrop-filter: blur(20px); }
  .sidebar-link.active { color: #94aaff; border-right: 2px solid #94aaff; background: rgba(19, 19, 20, 0.5); }
  @keyframes barPulse { 0%,100% { opacity: 0.6; } 50% { opacity: 1; } }
  .bar-animate { animation: barPulse 2s infinite; }
</style>
</head>
<body class="min-h-screen">

<!-- Ambient Aura -->
<div class="fixed inset-0 aura-blue pointer-events-none"></div>
<div class="fixed inset-0 aura-violet pointer-events-none"></div>

<!-- Sidebar -->
<aside id="sidebar" class="w-[280px] h-screen fixed left-0 top-0 bg-[#0a0a0b] flex flex-col border-r border-[#94aaff]/15 z-[60] shadow-[0px_20px_40px_rgba(0,0,0,0.4)] transform transition-transform lg:translate-x-0 -translate-x-full">
  <div class="p-8 pb-4">
    <div class="flex items-center gap-4 mb-10">
      <div class="relative flex items-center justify-center w-12 h-12 rounded-full p-[2px] bg-gradient-to-tr from-primary via-secondary to-primary-container">
        <div class="w-full h-full bg-[#0a0a0b] rounded-full flex items-center justify-center"><span class="text-white font-bold text-lg font-label">Ad</span></div>
      </div>
      <div>
        <h3 class="text-on-surface font-bold text-base leading-tight">Admin</h3>
        <p class="text-on-surface-variant text-[0.7rem] font-label uppercase tracking-wider">Superuser</p>
      </div>
    </div>
    <nav class="space-y-1">
      <a class="sidebar-link active flex items-center gap-4 px-6 py-3 transition-all hover:bg-[#131314]" href="/dashboard.html">
        <span class="material-symbols-outlined">dashboard</span><span class="font-label tracking-widest uppercase text-[0.75rem]">Overview</span>
      </a>
      <a class="sidebar-link flex items-center gap-4 text-[#adaaab] px-6 py-3 transition-all hover:bg-[#131314] hover:text-[#94aaff]" href="/admin/users">
        <span class="material-symbols-outlined">group</span><span class="font-label tracking-widest uppercase text-[0.75rem]">Users</span>
      </a>
      <a class="sidebar-link flex items-center gap-4 text-[#adaaab] px-6 py-3 transition-all hover:bg-[#131314] hover:text-[#94aaff]" href="/admin/messages">
        <span class="material-symbols-outlined">chat_bubble</span><span class="font-label tracking-widest uppercase text-[0.75rem]">Messages</span>
      </a>
      <a class="sidebar-link flex items-center gap-4 text-[#adaaab] px-6 py-3 transition-all hover:bg-[#131314] hover:text-[#94aaff]" href="/admin/memberships">
        <span class="material-symbols-outlined">card_membership</span><span class="font-label tracking-widest uppercase text-[0.75rem]">Memberships</span>
      </a>
      <a class="sidebar-link flex items-center gap-4 text-[#adaaab] px-6 py-3 transition-all hover:bg-[#131314] hover:text-[#94aaff]" href="/admin/settings">
        <span class="material-symbols-outlined">settings</span><span class="font-label tracking-widest uppercase text-[0.75rem]">Settings</span>
      </a>
    </nav>
  </div>
  <div class="mt-auto p-8 border-t border-outline-variant/10">
    <a class="flex items-center gap-4 text-[#adaaab] px-6 py-3 transition-all hover:bg-[#131314] hover:text-white mb-2" href="/">
      <span class="material-symbols-outlined">arrow_back</span><span class="font-label tracking-widest uppercase text-[0.75rem]">Back to Website</span>
    </a>
    <a id="logout-btn" class="flex items-center gap-4 text-error px-6 py-3 transition-all hover:bg-error/10 rounded-lg cursor-pointer" href="/admin/logout">
      <span class="material-symbols-outlined">logout</span><span class="font-label tracking-widest uppercase text-[0.75rem]">Logout</span>
    </a>
  </div>
</aside>

<!-- Mobile Sidebar Toggle -->
<button id="sidebar-toggle" class="lg:hidden fixed top-4 left-4 z-[70] bg-surface-container p-2 rounded-lg border border-white/10">
  <span class="material-symbols-outlined text-white">menu</span>
</button>

<!-- Top Bar -->
<header class="fixed top-0 right-0 w-full lg:w-[calc(100%-280px)] z-50 bg-[#0e0e0f]/60 backdrop-blur-[40px] flex justify-between items-center h-16 px-6 lg:px-8 lg:ml-[280px]">
  <div class="flex items-center gap-6 flex-1 ml-12 lg:ml-0">
    <div class="relative w-full max-w-md">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-sm">search</span>
      <input class="w-full bg-surface-container-high border-none rounded-full py-1.5 pl-10 pr-4 text-sm text-on-surface placeholder-on-surface-variant focus:ring-1 focus:ring-primary" placeholder="Search..." type="text"/>
    </div>
  </div>
  <div class="flex items-center gap-6">
    <div class="relative cursor-pointer">
      <span class="material-symbols-outlined text-on-surface-variant hover:text-white transition-colors">notifications</span>
      <span class="absolute top-0 right-0 w-2 h-2 bg-error rounded-full animate-pulse"></span>
    </div>
    <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-primary to-secondary flex items-center justify-center text-[10px] font-bold text-on-primary">AD</div>
  </div>
</header>

<!-- Main Content -->
<main class="lg:ml-[280px] pt-24 px-6 lg:px-8 pb-12 relative z-10">

  <!-- Welcome -->
  <section class="mb-12">
    <p class="font-label text-secondary tracking-[0.2em] uppercase text-[0.7rem] font-bold mb-2">Real-time Foundation Metrics & Control</p>
    <h1 class="font-headline text-3xl md:text-5xl font-extrabold text-on-surface tracking-tight">Welcome back, Admin 👋</h1>
  </section>

  <!-- KPI Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-10">
    <div class="glass-card p-6 rounded-xl flex flex-col gap-4">
      <div class="flex justify-between items-start">
        <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center"><span class="material-symbols-outlined text-primary">visibility</span></div>
        <span class="text-xs text-primary font-label flex items-center gap-1">+12% <span class="material-symbols-outlined text-[10px]">trending_up</span></span>
      </div>
      <div>
        <p class="text-[0.65rem] uppercase tracking-widest text-on-surface-variant font-label">Total Visitors</p>
        <h3 id="kpi-visitors" class="text-2xl font-bold text-on-surface">—</h3>
      </div>
    </div>
    <div class="glass-card p-6 rounded-xl flex flex-col gap-4">
      <div class="flex justify-between items-start">
        <div class="w-10 h-10 rounded-lg bg-secondary/10 flex items-center justify-center"><span class="material-symbols-outlined text-secondary">chat_bubble</span></div>
        <span class="text-xs text-secondary font-label flex items-center gap-1">+5% <span class="material-symbols-outlined text-[10px]">trending_up</span></span>
      </div>
      <div>
        <p class="text-[0.65rem] uppercase tracking-widest text-on-surface-variant font-label">Messages</p>
        <h3 id="kpi-messages" class="text-2xl font-bold text-on-surface">—</h3>
      </div>
    </div>
    <div class="glass-card p-6 rounded-xl flex flex-col gap-4">
      <div class="flex justify-between items-start">
        <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center"><span class="material-symbols-outlined text-amber-500">alternate_email</span></div>
        <span class="text-xs text-amber-500 font-label flex items-center gap-1">+8% <span class="material-symbols-outlined text-[10px]">trending_up</span></span>
      </div>
      <div>
        <p class="text-[0.65rem] uppercase tracking-widest text-on-surface-variant font-label">Subscribers</p>
        <h3 id="kpi-subscribers" class="text-2xl font-bold text-on-surface">—</h3>
      </div>
    </div>
    <div class="glass-card p-6 rounded-xl flex flex-col gap-4">
      <div class="flex justify-between items-start">
        <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center"><span class="material-symbols-outlined text-emerald-500">verified</span></div>
        <span class="text-xs text-emerald-500 font-label flex items-center gap-1">+18% <span class="material-symbols-outlined text-[10px]">trending_up</span></span>
      </div>
      <div>
        <p class="text-[0.65rem] uppercase tracking-widest text-on-surface-variant font-label">Pro Members</p>
        <h3 id="kpi-members" class="text-2xl font-bold text-on-surface">—</h3>
      </div>
    </div>
    <div class="glass-card p-6 rounded-xl flex flex-col gap-4">
      <div class="flex justify-between items-start">
        <div class="w-10 h-10 rounded-lg bg-cyan-400/10 flex items-center justify-center"><span class="material-symbols-outlined text-cyan-400">dns</span></div>
        <div class="flex gap-1"><div class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></div><div class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></div><div class="w-1.5 h-1.5 bg-surface-container-high rounded-full"></div></div>
      </div>
      <div>
        <p class="text-[0.65rem] uppercase tracking-widest text-on-surface-variant font-label">Server Health</p>
        <h3 id="kpi-server" class="text-2xl font-bold text-on-surface">—</h3>
      </div>
    </div>
  </div>

  <!-- Charts / Tables Row -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Donut Chart -->
    <div class="lg:col-span-1 glass-card p-8 rounded-xl">
      <h3 class="font-headline font-bold text-lg mb-6">Impact by Region</h3>
      <div class="flex items-center justify-center py-4">
        <div class="relative w-48 h-48">
          <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
            <circle cx="18" cy="18" r="15.915" fill="transparent" stroke="#19191b" stroke-width="3"></circle>
            <circle cx="18" cy="18" r="15.915" fill="transparent" stroke="#94aaff" stroke-width="3" stroke-dasharray="40 60" stroke-dashoffset="0"></circle>
            <circle cx="18" cy="18" r="15.915" fill="transparent" stroke="#cb7bff" stroke-width="3" stroke-dasharray="25 75" stroke-dashoffset="-40"></circle>
            <circle cx="18" cy="18" r="15.915" fill="transparent" stroke="#7daffc" stroke-width="3" stroke-dasharray="20 80" stroke-dashoffset="-65"></circle>
            <circle cx="18" cy="18" r="15.915" fill="transparent" stroke="#262627" stroke-width="3" stroke-dasharray="15 85" stroke-dashoffset="-85"></circle>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="text-3xl font-bold">88%</span>
            <span class="text-[0.6rem] font-label uppercase text-on-surface-variant tracking-widest">Growth</span>
          </div>
        </div>
      </div>
      <div class="mt-6 grid grid-cols-2 gap-4">
        <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-primary"></div><span class="text-xs text-on-surface-variant font-label">Rajasthan (40%)</span></div>
        <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-secondary"></div><span class="text-xs text-on-surface-variant font-label">MP (25%)</span></div>
        <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-tertiary-container"></div><span class="text-xs text-on-surface-variant font-label">UP (20%)</span></div>
        <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-surface-variant"></div><span class="text-xs text-on-surface-variant font-label">Bihar (15%)</span></div>
      </div>
    </div>

    <!-- Server + Messages -->
    <div class="lg:col-span-2 space-y-8">
      <!-- Server Performance -->
      <div class="glass-card p-8 rounded-xl">
        <div class="flex justify-between items-center mb-8">
          <h3 class="font-headline font-bold text-lg">Server Performance</h3>
          <div class="flex items-center gap-2 px-3 py-1 bg-emerald-500/10 rounded-full border border-emerald-500/20">
            <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></div>
            <span class="text-[0.65rem] text-emerald-500 font-bold uppercase tracking-widest font-label">Live</span>
          </div>
        </div>
        <div id="perf-bars" class="flex items-end justify-between h-32 gap-3">
          <!-- Bars injected by JS -->
        </div>
        <div class="mt-4 flex justify-between text-on-surface-variant text-[0.6rem] font-label uppercase tracking-widest">
          <span>12:00</span><span>14:00</span><span>16:00</span><span>18:00</span>
        </div>
      </div>

      <!-- Recent Messages -->
      <div class="glass-card rounded-xl overflow-hidden">
        <div class="p-8 pb-4"><h3 class="font-headline font-bold text-lg">Recent Messages</h3></div>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead class="bg-surface-container-low">
              <tr>
                <th class="px-8 py-4 text-[0.65rem] font-label uppercase tracking-widest text-on-surface-variant">Name</th>
                <th class="px-8 py-4 text-[0.65rem] font-label uppercase tracking-widest text-on-surface-variant">Subject</th>
                <th class="px-8 py-4 text-[0.65rem] font-label uppercase tracking-widest text-on-surface-variant">Date</th>
                <th class="px-8 py-4 text-[0.65rem] font-label uppercase tracking-widest text-on-surface-variant">Status</th>
              </tr>
            </thead>
            <tbody id="messages-table" class="divide-y divide-outline-variant/10">
              <tr><td colspan="4" class="px-8 py-6 text-center text-on-surface-variant">Loading messages...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- End Quick Action -->

</main>

<!-- Toast -->
<div id="toast" class="toast"></div>

<script>
// ====== SIDEBAR TOGGLE (Mobile) ======
const sidebar = document.getElementById('sidebar');
const sidebarToggle = document.getElementById('sidebar-toggle');
let sidebarOpen = false;
sidebarToggle?.addEventListener('click', () => {
  sidebarOpen = !sidebarOpen;
  sidebar.style.transform = sidebarOpen ? 'translateX(0)' : 'translateX(-100%)';
});

// ====== TOAST ======
function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  setTimeout(() => t.classList.remove('show'), 4000);
}

// ====== FETCH DASHBOARD DATA ======
async function loadDashboard() {
  try {
    const token = localStorage.getItem('adminToken') || document.cookie.replace(/(?:(?:^|.*;\s*)token\s*=\s*([^;]*).*$)|^.*$/, "$1");
    const headers = { 'Content-Type': 'application/json' };
    if (token) headers['Authorization'] = `Bearer ${token}`;

    const res = await fetch('/api/v1/health', { headers });
    const data = await res.json();

    if (data.data) {
      document.getElementById('kpi-visitors').textContent = (data.data.visitors || 0).toLocaleString();
      document.getElementById('kpi-messages').textContent = (data.data.contacts || 0).toLocaleString();
      document.getElementById('kpi-subscribers').textContent = (data.data.subscribers || 0).toLocaleString();
      document.getElementById('kpi-members').textContent = (data.data.members || 0).toLocaleString();
      document.getElementById('kpi-server').textContent = data.data.server === 'healthy' ? 'Optimal' : 'Degraded';
    }
  } catch {
    document.getElementById('kpi-visitors').textContent = '148.5k';
    document.getElementById('kpi-messages').textContent = '1,240';
    document.getElementById('kpi-subscribers').textContent = '8.2k';
    document.getElementById('kpi-members').textContent = '432';
    document.getElementById('kpi-server').textContent = 'Optimal';
  }

  // Load messages
  try {
    const token = localStorage.getItem('adminToken') || '';
    const res = await fetch('/admin/api/messages', { headers: { 'Authorization': `Bearer ${token}` } });
    if (res.ok) {
      const data = await res.json();
      const tbody = document.getElementById('messages-table');
      if (data.data && data.data.length > 0) {
        tbody.innerHTML = data.data.slice(0, 5).map(m => `
          <tr class="hover:bg-white/5 transition-colors">
            <td class="px-8 py-4"><div class="flex flex-col"><span class="text-sm font-bold">${m.name || 'Unknown'}</span><span class="text-xs text-on-surface-variant">${m.email || ''}</span></div></td>
            <td class="px-8 py-4 text-sm text-on-surface-variant">${m.subject || 'No subject'}</td>
            <td class="px-8 py-4 text-sm font-label text-on-surface-variant">${new Date(m.created_at || Date.now()).toLocaleDateString()}</td>
            <td class="px-8 py-4"><span class="px-2 py-1 text-[10px] font-bold uppercase tracking-tighter bg-primary/10 text-primary rounded">New</span></td>
          </tr>
        `).join('');
      } else {
        tbody.innerHTML = '<tr><td colspan="4" class="px-8 py-6 text-center text-on-surface-variant">No messages yet</td></tr>';
      }
    }
  } catch {
    // Fallback static data
    document.getElementById('messages-table').innerHTML = `
      <tr class="hover:bg-white/5 transition-colors"><td class="px-8 py-4"><div class="flex flex-col"><span class="text-sm font-bold">Arjun Mehta</span><span class="text-xs text-on-surface-variant">arjun@example.com</span></div></td><td class="px-8 py-4 text-sm text-on-surface-variant">Volunteer Application</td><td class="px-8 py-4 text-sm font-label text-on-surface-variant">Apr 15, 2025</td><td class="px-8 py-4"><span class="px-2 py-1 text-[10px] font-bold uppercase bg-primary/10 text-primary rounded">New</span></td></tr>
      <tr class="hover:bg-white/5 transition-colors"><td class="px-8 py-4"><div class="flex flex-col"><span class="text-sm font-bold">Priya Sharma</span><span class="text-xs text-on-surface-variant">priya@org.in</span></div></td><td class="px-8 py-4 text-sm text-on-surface-variant">Partnership Proposal</td><td class="px-8 py-4 text-sm font-label text-on-surface-variant">Apr 14, 2025</td><td class="px-8 py-4"><span class="px-2 py-1 text-[10px] font-bold uppercase bg-on-surface-variant/10 text-on-surface-variant rounded">Read</span></td></tr>
    `;
  }
}

// ====== PERF BARS (Animated) ======
function renderPerfBars() {
  const container = document.getElementById('perf-bars');
  const heights = [40, 65, 55, 80, 45, 70, 90, 50, 60, 35, 75, 85];
  container.innerHTML = heights.map((h, i) => 
    `<div class="w-full ${i === heights.length - 1 ? 'bg-primary' : 'bg-primary/20'} rounded-t-sm transition-all duration-500" style="height: ${h}%"></div>`
  ).join('');
  
  // Animate bars periodically
  setInterval(() => {
    const bars = container.querySelectorAll('div');
    bars.forEach(bar => {
      const newH = Math.floor(Math.random() * 60) + 30;
      bar.style.height = newH + '%';
    });
  }, 3000);
}

// ====== LOGOUT ======
document.getElementById('logout-btn')?.addEventListener('click', (e) => {
  e.preventDefault();
  localStorage.removeItem('adminToken');
  document.cookie = 'token=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT;';
  window.location.href = '/admin/login.html';
});


// Init
loadDashboard();
renderPerfBars();
</script>
</body>
</html>
