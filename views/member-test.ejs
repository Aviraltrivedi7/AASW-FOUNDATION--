<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Razorpay + InsForge Test Form</title>
    <!-- Include Razorpay SDK -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <style>
        body { font-family: sans-serif; padding: 40px; background: #f9f9f9; }
        .container { max-width: 400px; padding: 20px; background: #fff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input { width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        button { padding: 10px 15px; width: 100%; background: #2563eb; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
        button:disabled { background: #9ca3af; }
        #msg { margin-top: 15px; font-weight: bold; padding: 10px; border-radius: 4px; display: none; }
        .success { background: #dcfce3; color: #15803d; border: 1px solid #16a34a; }
        .error { background: #fee2e2; color: #b91c1c; border: 1px solid #dc2626; }
        .processing { background: #eef2ff; color: #4338ca; border: 1px solid #6366f1; }
    </style>
</head>
<body>

    <div class="container">
        <h2>Become a Member (Razorpay)</h2>
        <form id="memberForm">
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" required>
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" required>
            </div>
            <button type="submit" id="submitBtn">Pay & Join</button>
        </form>
        <p id="msg"></p>
    </div>

    <script>
        const msgEl = document.getElementById('msg');
        
        function showMessage(text, type) {
            msgEl.textContent = text;
            msgEl.className = type;
            msgEl.style.display = 'block';
        }

        document.getElementById('memberForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const submitBtn = document.getElementById('submitBtn');

            // 1. Initial Processing State
            submitBtn.textContent = 'Processing Payment...';
            submitBtn.disabled = true;
            showMessage('Initializing payment interface...', 'processing');

            try {
                // 2. Fetch Order from Backend
                const orderRes = await fetch('/api/members/create-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount: 500 }) // Request a 500 INR order
                });

                const orderData = await orderRes.json();
                
                if (!orderRes.ok) {
                    throw new Error(orderData.error || 'Failed to initialize payment');
                }

                showMessage('Opening secure gateway...', 'processing');

                // 3. Configure Razorpay Options
                const options = {
                    key: orderData.keyId,
                    amount: orderData.amount,
                    currency: "INR",
                    name: "AASW Foundation",
                    description: "Membership Subscription",
                    order_id: orderData.orderId,
                    handler: async function (response) {
                        try {
                            showMessage('Payment complete. Verifying secure signature...', 'processing');

                            // 4. On Success, Verify Signature & Add to Database
                            const verifyRes = await fetch('/api/members', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    name: name,
                                    email: email,
                                    razorpay_order_id: response.razorpay_order_id,
                                    razorpay_payment_id: response.razorpay_payment_id,
                                    razorpay_signature: response.razorpay_signature
                                })
                            });

                            const resultObj = await verifyRes.json();

                            if (verifyRes.ok) {
                                showMessage('Payment Successful & Member Added!', 'success');
                                document.getElementById('memberForm').reset();
                            } else {
                                showMessage(resultObj.error || 'Verification failed.', 'error');
                            }
                        } catch (err) {
                            console.error(err);
                            showMessage('Network error during verification.', 'error');
                        } finally {
                            submitBtn.textContent = 'Pay & Join';
                            submitBtn.disabled = false;
                        }
                    },
                    prefill: {
                        name: name,
                        email: email
                    },
                    theme: {
                        color: "#2563eb"
                    }
                };

                // 5. Open Razorpay Check
                const rzp = new Razorpay(options);
                rzp.on('payment.failed', function (response) {
                    showMessage('Payment Failed or Cancelled.', 'error');
                    submitBtn.textContent = 'Pay & Join';
                    submitBtn.disabled = false;
                });
                rzp.open();

            } catch (err) {
                showMessage(err.message || 'Error occurred.', 'error');
                submitBtn.textContent = 'Pay & Join';
                submitBtn.disabled = false;
                console.error(err);
            }
        });
    </script>

<!-- Toast Container -->
<div id="toast" class="toast"></div>

<style>
  /* Toast notification */
  .toast { position: fixed; bottom: 2rem; right: 2rem; padding: 1rem 1.5rem; border-radius: 0.75rem; z-index: 100; transform: translateY(100px); opacity: 0; transition: all 0.4s ease; pointer-events: none; }
  .toast.show { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .toast.success { background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3); color: #22c55e; backdrop-filter: blur(20px); }
  .toast.error { background: rgba(255, 110, 132, 0.15); border: 1px solid rgba(255, 110, 132, 0.3); color: #ff6e84; backdrop-filter: blur(20px); }
</style>

<script>
// ====== TOAST NOTIFICATION ======
function showToast(message, type = 'success') {
  let toast = document.getElementById('toast');
  if(!toast) return;
  toast.textContent = message;
  toast.className = 'toast ' + type + ' show';
  setTimeout(() => toast.classList.remove('show'), 4000);
}

// ====== GENERIC FORM HANDLERS ======
document.querySelectorAll('form').forEach(form => {
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameInput = form.querySelector('input[placeholder*="Doe"]');
    const emailInput = form.querySelector('input[type="email"]');
    const msgInput = form.querySelector('textarea');
    const btn = form.querySelector('button');
    const originalText = btn ? btn.textContent : 'Sending...';
    
    // Contact form check
    if (nameInput && emailInput && msgInput) {
        if (btn) { btn.textContent = 'Sending...'; btn.disabled = true; }
        try {
          const res = await fetch('/api/v1/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: nameInput.value,
              email: emailInput.value,
              subject: 'Contact from Stitch UI',
              message: msgInput.value
            })
          });
          if (res.ok) {
            showToast('✓ Message sent successfully!', 'success');
            form.reset();
          } else {
            showToast('Failed to send message', 'error');
          }
        } catch (err) {
          showToast('Network error. Please try again.', 'error');
        } finally {
          if (btn) { btn.textContent = originalText; btn.disabled = false; }
        }
    }
  });
});
</script>

</body>
</html>
