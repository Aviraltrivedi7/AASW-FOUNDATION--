<body class="font-body selection:bg-primary selection:text-on-primary overflow-x-hidden">

<!-- Navigation -->
<header class="fixed top-0 w-full z-50 bg-[#0e0e0f]/60 backdrop-blur-xl shadow-[0px_20px_40px_rgba(0,0,0,0.4)]">
  <%- include('partials/navbar') %>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="mobile-menu fixed inset-0 z-[70] bg-background/95 backdrop-blur-xl flex flex-col items-center justify-center gap-8">
