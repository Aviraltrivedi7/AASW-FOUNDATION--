<main class="pt-24">

<!-- Hero -->
<section class="relative py-20 md:py-28 text-center px-6 overflow-hidden">
  <div class="absolute -top-20 -right-20 w-[500px] h-[500px] aura-blue blur-[120px] opacity-30"></div>
  <div class="absolute -bottom-20 -left-20 w-[500px] h-[500px] aura-purple blur-[120px] opacity-20"></div>
  <div class="relative z-10 max-w-4xl mx-auto fade-up">
    <span class="font-label text-xs uppercase tracking-[0.3em] text-primary mb-4 block">Data Protection</span>
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-headline font-extrabold tracking-tight mb-6 leading-tight">Privacy <span class="text-gradient">Policy</span></h1>
    <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">How we collect, use, and protect your personal data when you interact with AASW Foundation.</p>
  </div>
</section>

<!-- Privacy Content -->
<section class="py-16 md:py-24 px-6 md:px-12">
  <div class="max-w-4xl mx-auto">
    <div class="mb-12 fade-up">
      <span class="font-label text-xs uppercase tracking-widest text-secondary">Your Privacy Matters</span>
      <h2 class="text-3xl md:text-4xl font-headline font-bold mt-2">Privacy & Data Protection</h2>
      <p class="text-on-surface-variant mt-4 leading-relaxed max-w-3xl">AASW Foundation respects your privacy and is committed to protecting your personal data when you interact with our website, donate, or volunteer with us.</p>
    </div>

    <div class="space-y-8">
      <!-- Section 1 -->
      <div class="policy-section pl-8 py-6 transition-all duration-300 fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center border border-primary/20">
            <span class="material-symbols-outlined text-primary">inventory_2</span>
          </div>
          <h3 class="text-xl font-headline font-bold text-white">1. Information We Collect</h3>
        </div>
        <p class="text-on-surface-variant leading-relaxed">We may collect personal identification information including your name, email address, phone number, and mailing address when you make a donation or subscribe to our newsletter. Payment details are processed securely by our trusted gateway partners (Razorpay/PayU) and are not stored on our servers.</p>
      </div>

      <!-- Section 2 -->
      <div class="policy-section pl-8 py-6 transition-all duration-300 fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center border border-secondary/20">
            <span class="material-symbols-outlined text-secondary">dataset</span>
          </div>
          <h3 class="text-xl font-headline font-bold text-white">2. How We Use Your Information</h3>
        </div>
        <ul class="space-y-3 text-on-surface-variant">
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg mt-0.5">check_circle</span>
            <span>To process donations and issue 80G tax limit receipts.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg mt-0.5">check_circle</span>
            <span>To send periodic updates, newsletters, and impact reports.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg mt-0.5">check_circle</span>
            <span>To improve our website functionality and user experience.</span>
          </li>
        </ul>
      </div>

      <!-- Section 3 -->
      <div class="policy-section pl-8 py-6 transition-all duration-300 fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 rounded-xl bg-tertiary/10 flex items-center justify-center border border-tertiary/20">
            <span class="material-symbols-outlined text-tertiary">shield</span>
          </div>
          <h3 class="text-xl font-headline font-bold text-white">3. Data Security</h3>
        </div>
        <p class="text-on-surface-variant leading-relaxed">We implement a variety of security measures to maintain the safety of your personal information. We do not sell, trade, or otherwise transfer your personally identifiable information to outside parties without your explicit consent.</p>
      </div>

      <!-- Section 4 -->
      <div class="policy-section pl-8 py-6 transition-all duration-300 fade-up">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center border border-primary/20">
            <span class="material-symbols-outlined text-primary">contact_support</span>
          </div>
          <h3 class="text-xl font-headline font-bold text-white">4. Contacting Us</h3>
        </div>
        <p class="text-on-surface-variant leading-relaxed mb-4">If there are any questions regarding this privacy policy, you may contact us via:</p>
        <div class="glass p-6 rounded-xl border border-white/5 space-y-3">
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-lg">mail</span>
            <span class="text-on-surface-variant text-sm">aaswfoundation06@gmail.com</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-lg">call</span>
            <span class="text-on-surface-variant text-sm">+91 9984156418</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-lg">location_on</span>
            <span class="text-on-surface-variant text-sm">Ward No 2 Ambedkar Nagar Rura, Kanpur Dehat, Uttar Pradesh</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</main>

<!-- Footer -->
<%- include('partials/footer') %>

<script>
document.getElementById('menu-toggle')?.addEventListener('click', () => document.getElementById('mobile-menu').classList.add('open'));
document.getElementById('menu-close')?.addEventListener('click', () => document.getElementById('mobile-menu').classList.remove('open'));
const obs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
}, { threshold: 0.1 });
document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
</script>

<!-- Toast Container -->
<div id="toast" class="toast"></div>

<style>
  /* Toast notification */
  .toast { position: fixed; bottom: 2rem; right: 2rem; padding: 1rem 1.5rem; border-radius: 0.75rem; z-index: 100; transform: translateY(100px); opacity: 0; transition: all 0.4s ease; pointer-events: none; }
  .toast.show { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .toast.success { background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3); color: #22c55e; backdrop-filter: blur(20px); }
  .toast.error { background: rgba(255, 110, 132, 0.15); border: 1px solid rgba(255, 110, 132, 0.3); color: #ff6e84; backdrop-filter: blur(20px); }
</style>

<script>
// ====== TOAST NOTIFICATION ======
function showToast(message, type = 'success') {
  let toast = document.getElementById('toast');
  if(!toast) return;
  toast.textContent = message;
  toast.className = 'toast ' + type + ' show';
  setTimeout(() => toast.classList.remove('show'), 4000);
}

// ====== GENERIC FORM HANDLERS ======
document.querySelectorAll('form').forEach(form => {
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameInput = form.querySelector('input[placeholder*="Doe"]');
    const emailInput = form.querySelector('input[type="email"]');
    const msgInput = form.querySelector('textarea');
    const btn = form.querySelector('button');
    const originalText = btn ? btn.textContent : 'Sending...';
    
    // Contact form check
    if (nameInput && emailInput && msgInput) {
        if (btn) { btn.textContent = 'Sending...'; btn.disabled = true; }
        try {
          const res = await fetch('/api/v1/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: nameInput.value,
              email: emailInput.value,
              subject: 'Contact from Stitch UI',
              message: msgInput.value
            })
          });
          if (res.ok) {
            showToast('✓ Message sent successfully!', 'success');
            form.reset();
          } else {
            showToast('Failed to send message', 'error');
          }
        } catch (err) {
          showToast('Network error. Please try again.', 'error');
        } finally {
          if (btn) { btn.textContent = originalText; btn.disabled = false; }
        }
    }
  });
});
</script>

</body>
</html>