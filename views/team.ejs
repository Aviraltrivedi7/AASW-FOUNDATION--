<!-- Team Switching Logic -->
<script>
function switchTeam(category) {
    // Update Buttons
    document.querySelectorAll(".team-tab-btn").forEach(btn => {
        btn.classList.remove("active", "border-primary/30", "bg-primary/5");
    });
    const activeBtn = document.getElementById("btn-" + category);
    activeBtn.classList.add("active", "border-primary/30", "bg-primary/5");

    // Update Content with animation
    const sections = document.querySelectorAll(".team-content-section");
    sections.forEach(section => {
        section.classList.add("hidden", "opacity-0", "translate-y-8");
    });

    const activeSection = document.getElementById("team-" + category);
    activeSection.classList.remove("hidden");
    
    // Tiny timeout to trigger CSS transition
    setTimeout(() => {
        activeSection.classList.remove("opacity-0", "translate-y-8");
    }, 10);
}

// Ensure first category is styled on load
document.addEventListener("DOMContentLoaded", () => {
    const coreBtn = document.getElementById("btn-core");
    if(coreBtn) coreBtn.classList.add("active", "border-primary/30", "bg-primary/5");
});
</script>

